<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= site.site_title || '部门综合服务平台' %></title>
  <style>
    :root {
      --text: #0d1b38;
      --muted: #66748c;
      --blue: #2f78ff;
      --panel: rgba(255, 255, 255, 0.86);
      --line: rgba(48, 104, 190, 0.13);
      --shadow: 0 20px 45px rgba(20, 57, 114, 0.10);
      --shadow-hover: 0 26px 55px rgba(31, 88, 178, 0.18);
      --radius: 22px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Microsoft YaHei", "PingFang SC", "Noto Sans SC", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 13% 18%, rgba(255,255,255,.92) 0 2.6rem, transparent 2.7rem),
        radial-gradient(circle at 6% 47%, rgba(255,255,255,.75) 0 3.2rem, transparent 3.3rem),
        linear-gradient(118deg, #f9fcff 0%, #eef7ff 38%, #dbeaff 100%);
      overflow-x: hidden;
    }

    .page {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .page::before {
      content: "";
      position: absolute;
      inset: 120px -120px 90px -80px;
      pointer-events: none;
      background:
        linear-gradient(115deg, transparent 0 28%, rgba(255,255,255,.62) 28.2% 28.6%, transparent 28.8%),
        linear-gradient(115deg, transparent 0 33%, rgba(255,255,255,.52) 33.2% 33.5%, transparent 33.8%),
        linear-gradient(115deg, transparent 0 41%, rgba(255,255,255,.45) 41.2% 41.45%, transparent 41.8%),
        radial-gradient(ellipse at 88% 18%, rgba(68, 132, 229, .18), transparent 44%),
        radial-gradient(ellipse at 18% 88%, rgba(55, 121, 222, .14), transparent 45%);
      opacity: .95;
    }

    .skyline {
      position: absolute;
      right: -12px;
      top: 140px;
      width: min(39vw, 660px);
      height: 160px;
      opacity: .22;
      pointer-events: none;
      filter: drop-shadow(0 8px 25px rgba(70, 119, 196, .18));
    }

    header {
      position: relative;
      z-index: 2;
      height: 118px;
      padding: 0 clamp(28px, 4.6vw, 80px);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(255,255,255,.76);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(85, 125, 184, .13);
      box-shadow: 0 8px 22px rgba(45, 91, 156, .04);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .logo {
      width: 62px;
      height: 62px;
      flex: 0 0 auto;
      border-radius: 50%;
      background: linear-gradient(145deg, #ffffff, #eaf3ff);
      border: 2px solid rgba(38, 92, 174, .30);
      box-shadow: inset 0 0 0 6px rgba(47, 120, 255, .05), 0 10px 24px rgba(33, 88, 166, .12);
      display: grid;
      place-items: center;
    }

    .brand-title {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .brand-title h1 {
      margin: 0;
      font-size: clamp(24px, 2.15vw, 34px);
      letter-spacing: 4px;
      line-height: 1.1;
      color: #0b2b68;
      font-weight: 800;
      white-space: nowrap;
    }

    .brand-title span {
      font-size: clamp(13px, 1.05vw, 18px);
      letter-spacing: 3px;
      color: #63728a;
      white-space: nowrap;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 24px;
      font-size: 15px;
      color: #172a4a;
      white-space: nowrap;
    }

    .top-action {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .divider {
      height: 20px;
      width: 1px;
      background: rgba(46, 76, 121, .18);
    }

    main {
      position: relative;
      z-index: 1;
      flex: 1;
      padding: clamp(38px, 6vh, 76px) clamp(26px, 10vw, 175px) clamp(34px, 5vh, 70px);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .portal-grid {
      width: min(1260px, 100%);
      display: grid;
      grid-template-columns: repeat(6, minmax(135px, 1fr));
      gap: clamp(20px, 2.2vw, 34px) clamp(20px, 2.2vw, 34px);
    }

    .card {
      position: relative;
      min-height: 212px;
      padding: 28px 18px 22px;
      border: 1px solid rgba(255, 255, 255, .92);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 18px;
      text-decoration: none;
      color: var(--text);
      overflow: hidden;
      transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease, background .25s ease;
    }

    .card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(145deg, rgba(255,255,255,.66), transparent 52%);
      pointer-events: none;
    }

    .card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-hover);
      border-color: rgba(76, 139, 255, .24);
      background: rgba(255,255,255,.95);
    }

    .icon-wrap {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      position: relative;
      z-index: 1;
    }

    .icon-wrap svg {
      width: 58px;
      height: 58px;
      stroke-width: 1.9;
    }

    .blue { background: linear-gradient(145deg, rgba(47,120,255,.12), rgba(47,120,255,.03)); color: #2878f2; }
    .teal { background: linear-gradient(145deg, rgba(36,190,174,.15), rgba(36,190,174,.04)); color: #23b9ad; }
    .purple { background: linear-gradient(145deg, rgba(119,91,246,.15), rgba(119,91,246,.04)); color: #7560f1; }
    .orange { background: linear-gradient(145deg, rgba(244,171,42,.18), rgba(244,171,42,.05)); color: #f1a625; }
    .red { background: linear-gradient(145deg, rgba(234,79,86,.15), rgba(234,79,86,.04)); color: #e6505b; }
    .green { background: linear-gradient(145deg, rgba(45,188,139,.15), rgba(45,188,139,.04)); color: #24ae86; }

    .name {
      position: relative;
      z-index: 1;
      width: 100%;
      overflow: hidden;
      text-align: center;
    }

    .name-inner {
      display: inline-block;
      white-space: nowrap;
      font-size: clamp(17px, 1.25vw, 22px);
      font-weight: 700;
      letter-spacing: 2px;
      animation: name-marquee 4s ease-in-out infinite;
    }

    @keyframes name-marquee {
      0%, 20%   { transform: translateX(0); }
      45%, 55%  { transform: translateX(min(0px, calc(110px - 100%))); }
      80%, 100% { transform: translateX(0); }
    }

    .chevron {
      position: relative;
      z-index: 1;
      color: #5b6780;
      font-size: 30px;
      line-height: .55;
      transform: translateY(-1px);
      transition: transform .25s ease, color .25s ease;
    }

    .card:hover .chevron {
      transform: translateX(4px) translateY(-1px);
      color: var(--blue);
    }

    footer {
      position: relative;
      z-index: 2;
      min-height: 62px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 26px;
      padding: 12px 24px;
      color: #7a8497;
      font-size: 14px;
      background: rgba(255, 255, 255, .56);
      border-top: 1px solid rgba(86, 128, 185, .18);
      backdrop-filter: blur(12px);
    }

    footer span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    footer i {
      display: block;
      width: 1px;
      height: 16px;
      background: rgba(82, 103, 132, .24);
    }

    svg { display: block; }

    @media (max-width: 1180px) {
      .portal-grid { grid-template-columns: repeat(4, 1fr); }
      header { height: auto; min-height: 104px; gap: 20px; }
      .top-actions { gap: 14px; }
    }

    @media (max-width: 760px) {
      header { align-items: flex-start; flex-direction: column; padding-top: 22px; padding-bottom: 18px; }
      .brand-title h1 { letter-spacing: 2px; }
      .brand-title span { letter-spacing: 1px; }
      .logo { width: 52px; height: 52px; }
      .portal-grid { grid-template-columns: repeat(2, 1fr); }
      .card { min-height: 178px; }
      .icon-wrap { width: 78px; height: 78px; }
      .icon-wrap svg { width: 48px; height: 48px; }
      footer { flex-wrap: wrap; gap: 12px; }
    }
  </style>
</head>
<body>
  <div class="page">
    <svg class="skyline" viewBox="0 0 700 180" fill="none" aria-hidden="true">
      <path d="M6 153H694" stroke="#4c85d6" stroke-width="2"/>
      <path d="M70 153V66H137V153M92 91H115M92 113H115M92 135H115" stroke="#4c85d6" stroke-width="2"/>
      <path d="M153 153V38H234V153M174 63H196M174 89H196M174 115H196M207 63H222M207 89H222M207 115H222" stroke="#4c85d6" stroke-width="2"/>
      <path d="M265 153V79H350V153M285 100H307M285 122H307M323 100H338M323 122H338" stroke="#4c85d6" stroke-width="2"/>
      <path d="M377 153V52L451 32L529 52V153M405 76H429M405 103H429M405 130H429M462 76H491M462 103H491M462 130H491" stroke="#4c85d6" stroke-width="2"/>
      <path d="M560 153V88H650V153M579 111H604M579 132H604M619 111H635M619 132H635" stroke="#4c85d6" stroke-width="2"/>
    </svg>

    <header>
      <div class="brand">
        <div class="logo" aria-label="部门 logo">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="24" cy="24" r="21" stroke="#1e5fac" stroke-width="1.6" stroke-dasharray="2.3 2.3"/>
            <path d="M15 14.8c5.4 0 7.3 2.1 9 4.1 1.7-2 3.6-4.1 9-4.1v18.5c-4.8 0-7 1.4-9 3.2-2-1.8-4.2-3.2-9-3.2V14.8z" fill="#2c6ed2" opacity=".92"/>
            <path d="M24 19v17.4" stroke="white" stroke-width="1.5" opacity=".9"/>
            <path d="M18.5 19.5c2.5.25 4 .92 5.5 2.2M29.5 19.5c-2.5.25-4 .92-5.5 2.2" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="brand-title">
          <h1><%= site.site_title || '部门综合服务平台' %></h1>
          <span><%= site.site_subtitle || '统一业务导航平台' %></span>
        </div>
      </div>

      <div class="top-actions">
        <span class="top-action">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 7h18s-3 0-3-7"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          通知
        </span>
        <span class="divider"></span>
        <span class="top-action">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
          您好，欢迎登录
        </span>
      </div>
    </header>

    <main>
      <section class="portal-grid" aria-label="系统入口">
        <% cards.forEach(function(card) { %>
        <a class="card" href="<%= card.link_url || '#' %>" title="<%= card.title %>">
          <span class="icon-wrap <%= card.icon_color || 'blue' %>"><%- card.icon_svg %></span>
          <span class="name"><span class="name-inner"><%= card.title %></span></span><span class="chevron">›</span>
        </a>
        <% }); %>

        <% if (!cards || cards.length === 0) { %>
        <div style="grid-column:1/-1;text-align:center;color:#8896aa;padding:40px">
          暂未添加系统入口，请登录管理后台添加
        </div>
        <% } %>
      </section>
    </main>

    <footer>
      <span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-5"/></svg>
        安全　规范　高效　服务
      </span>
      <i></i>
      <span>© 2024 部门综合服务平台　版权所有</span>
      <i></i>
      <span>联系我们</span>
    </footer>
  </div>
</body>
</html>
